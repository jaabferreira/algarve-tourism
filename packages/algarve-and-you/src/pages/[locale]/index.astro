---
import { getCollection } from "astro:content";
import type { Locale } from "@algarve-tourism/shared";
import type { TranslationKey } from "@algarve-tourism/shared";
import { LOCALES, t } from "@algarve-tourism/shared";
import Layout from "../../layouts/Layout.astro";
import Header from "@algarve-tourism/shared/components/Header.astro";
import Footer from "@algarve-tourism/shared/components/Footer.astro";
import HeroSection from "@algarve-tourism/shared/components/HeroSection.astro";
import ProductGrid from "@algarve-tourism/shared/components/ProductGrid.astro";
import CategoryCard from "@algarve-tourism/shared/components/CategoryCard.astro";
import ReviewsGrid from "@algarve-tourism/shared/components/ReviewsGrid.astro";
import WhatsAppButton from "@algarve-tourism/shared/components/WhatsAppButton.astro";
import Marquee from "@algarve-tourism/shared/components/Marquee.astro";
import EditorialQuote from "@algarve-tourism/shared/components/EditorialQuote.astro";
import SectionDivider from "@algarve-tourism/shared/components/SectionDivider.astro";
import BlogCard from "@algarve-tourism/shared/components/BlogCard.astro";
import { config } from "../../config.js";
import { getLocalePath, buildLocalBusiness } from "@algarve-tourism/shared";
import manualReviews from "../../content/reviews/manual.json";
import { loadItems } from "../../data.js";

export function getStaticPaths() {
  return LOCALES.map((locale) => ({ params: { locale } }));
}

const locale = Astro.params.locale as Locale;
const path = "/";

const structuredData = buildLocalBusiness(config);

const items = loadItems(locale);

// Pick one item per category first, then fill remaining slots
const categories = config.fh.categories;
const pickedPks = new Set<number>();
const diverseItems: typeof items = [];

for (const cat of categories) {
  const match = items.find((item) => item.category === cat && !pickedPks.has(item.pk));
  if (match) {
    diverseItems.push(match);
    pickedPks.add(match.pk);
  }
}
// Fill remaining slots up to 6 with items not yet picked
for (const item of items) {
  if (diverseItems.length >= 6) break;
  if (!pickedPks.has(item.pk)) {
    diverseItems.push(item);
    pickedPks.add(item.pk);
  }
}
const featuredItems = diverseItems;

// Build category cards with representative images from each category
const categoryCards = categories.map((cat) => {
  const catItems = items.filter((item) => item.category === cat);
  const image = catItems[0]?.images?.[0]?.url || catItems[0]?.image_url || "";
  return {
    slug: cat,
    name: t(locale, `category.${cat}` as TranslationKey),
    image,
    href: getLocalePath(locale, `/tours/${cat}/`),
  };
}).filter((c) => c.image);

const topReviews = manualReviews.filter((r) => r.rating >= 4).slice(0, 3);

// Hero image candidates — uncomment to try:
// 1. Benagil cave gallery: "https://cdn.filestackcontent.com/resize=width:1920,fit:max/quality=value:85/r5ANbJiiTTUEF7dC8OAn"
// 2. Benagil cave gallery: "https://cdn.filestackcontent.com/resize=width:1920,fit:max/quality=value:85/BKMaJdWRcCnfS00Ch4As"
// 3. Benagil full caves: "https://cdn.filestackcontent.com/resize=width:1920,fit:max/quality=value:85/jMaP9WzHS4Gak31H6yia"
// 4. Benagil full caves: "https://cdn.filestackcontent.com/resize=width:1920,fit:max/quality=value:85/DlXwGycPTSuGCB8qYiHE"
// 5. Speedboat Benagil: "https://cdn.filestackcontent.com/resize=width:1920,fit:max/quality=value:85/bT14MOwPTli7XyXt79eR"
const heroImage = "https://cdn.filestackcontent.com/resize=width:1920,fit:max/quality=value:85/bT14MOwPTli7XyXt79eR";

let heroTitle = config.tagline;
let heroSubtitle = "";
try {
  const page = await getCollection("pages");
  const homePage = page.find((p) => p.id === `${locale}/homepage` || p.id === `${locale}/homepage.md`);
  if (homePage) {
    heroTitle = homePage.data.title;
    heroSubtitle = homePage.data.description ?? "";
  }
} catch {}

// Float card data from first featured item
const firstItem = featuredItems[0];
const floatLabel = firstItem?.category
  ? firstItem.category.replace(/-/g, " ").replace(/\b\w/g, (l) => l.toUpperCase())
  : undefined;
const floatTitle = firstItem?.name;
const floatMeta = firstItem?.price_from
  ? `From €${firstItem.price_from}`
  : undefined;
const floatHref = firstItem?.slug
  ? getLocalePath(locale, `/tours/${firstItem.slug}/`)
  : undefined;

// Editorial quote — pick best review (5-star first, fallback to first)
const quoteReview =
  manualReviews.find((r) => r.rating >= 5) || manualReviews[0];

// Blog posts
const marqueeText = t(locale, "marquee.ay");

let blogPosts: Awaited<ReturnType<typeof getCollection<"blog">>> = [];
try {
  const allPosts = await getCollection("blog");
  blogPosts = allPosts
    .filter((post) => post.data.locale === locale)
    .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
    .slice(0, 3);
} catch {}
---

<Layout
  title={heroTitle}
  description={t(locale, "meta.home_ay")}
  locale={locale}
  path={path}
  config={config}
  structuredData={structuredData}
  heroImage={heroImage}
>
  <Header slot="header" config={config} locale={locale} path={`/${locale}${path}`} />

  <HeroSection
    config={config}
    locale={locale}
    title={heroTitle}
    subtitle={heroSubtitle}
    ctaText={t(locale, "hero.cta")}
    ctaLink={getLocalePath(locale, "/tours/")}
    image={heroImage}
    floatLabel={floatLabel}
    floatTitle={floatTitle}
    floatMeta={floatMeta}
    floatHref={floatHref}
  />

  <Marquee text={marqueeText} />

  {categoryCards.length > 0 && (
    <section class="section">
      <div class="container">
        <div class="section-header">
          <div>
            <p class="section-label">{t(locale, "home.curated_label")}</p>
            <h2 class="section-title" set:html={t(locale, "home.curated_title")} />
          </div>
          <a href={getLocalePath(locale, "/tours/")} class="see-all">{t(locale, "home.view_all_experiences")} &rarr;</a>
        </div>
        <div class="category-grid" data-reveal-stagger>
          {categoryCards.map((cat, i) => (
            <div
              class:list={["category-grid__item", { "category-grid__item--featured": i === 0 }]}
              data-reveal
              style={`--reveal-delay: ${i * 40}ms`}
            >
              <CategoryCard
                name={cat.name}
                href={cat.href}
                image={cat.image}
                locale={locale}
                featured={i === 0}
              />
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  <SectionDivider text={t(locale, "home.divider_text")} />

  {quoteReview && (
    <EditorialQuote
      text={quoteReview.text}
      author={quoteReview.author}
      origin={quoteReview.origin}
    />
  )}

  {topReviews.length > 0 && (
    <section class="section">
      <div class="container">
        <div class="section-header">
          <div>
            <p class="section-label">{t(locale, "home.guest_voices")}</p>
            <h2 class="section-title" set:html={t(locale, "home.guest_voices_title")} />
          </div>
          <a href={getLocalePath(locale, "/reviews/")} class="see-all">{t(locale, "home.all_reviews")} &rarr;</a>
        </div>
        <ReviewsGrid reviews={topReviews} brand={config.brand} locale={locale} />
      </div>
    </section>
  )}

  {blogPosts.length > 0 && (
    <section class="section">
      <div class="container">
        <div class="section-header">
          <div>
            <p class="section-label">{t(locale, "home.journal_label")}</p>
            <h2 class="section-title" set:html={t(locale, "home.journal_title")} />
          </div>
          <a href={getLocalePath(locale, "/blog/")} class="see-all">{t(locale, "blog.read_more")} &rarr;</a>
        </div>
        <div class="journal-grid">
          {blogPosts.map((post) => (
            <BlogCard
              title={post.data.title}
              excerpt={post.data.excerpt}
              slug={post.slug.replace(`${locale}/`, "")}
              image={post.data.image}
              date={post.data.date}
              locale={locale}
              brand={config.brand}
            />
          ))}
        </div>
      </div>
    </section>
  )}

  <Footer slot="footer" config={config} locale={locale} />
  <WhatsAppButton phone={config.social.whatsapp} locale={locale} />
</Layout>

<style>
  .section-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    margin-bottom: var(--space-10);
  }
  .section-label {
    font-size: var(--text-xs);
    font-weight: var(--weight-medium);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wider);
    color: var(--color-primary);
    margin-bottom: var(--space-2);
  }
  .section-title {
    font-family: var(--font-display);
    font-size: var(--text-4xl);
    font-weight: var(--weight-light);
    color: var(--color-text);
  }
  .section-title em {
    font-style: italic;
    color: var(--color-primary);
  }
  .see-all {
    font-size: var(--text-xs);
    color: var(--color-text);
    font-weight: var(--weight-medium);
    text-decoration: none;
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    transition: color var(--transition-fast);
  }
  .see-all:hover {
    color: var(--color-primary);
  }
  .category-grid {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    grid-auto-rows: auto;
    gap: var(--space-6);
  }
  .category-grid__item {
    display: flex;
  }
  .category-grid__item > :global(*) {
    flex: 1;
    min-height: 0;
  }
  .category-grid__item--featured {
    grid-row: span 2;
  }
  .category-grid__item[data-reveal] {
    opacity: 0;
    transform: translateY(16px);
    transition: opacity 0.3s ease, transform 0.3s ease;
    transition-delay: var(--reveal-delay, 0ms);
  }
  .category-grid__item[data-reveal].revealed {
    opacity: 1;
    transform: translateY(0);
  }
  @media (prefers-reduced-motion: reduce) {
    .category-grid__item[data-reveal] {
      opacity: 1;
      transform: none;
      transition: none;
    }
  }
  @media (max-width: 960px) {
    .category-grid {
      grid-template-columns: 1fr 1fr;
    }
  }
  @media (max-width: 640px) {
    .category-grid {
      grid-template-columns: 1fr;
    }
    .category-grid__item--featured {
      grid-row: span 1;
    }
  }
  .journal-grid {
    display: grid;
    grid-template-columns: 1.4fr 1fr 1fr;
    gap: var(--space-5);
  }
  @media (max-width: 960px) {
    .journal-grid {
      grid-template-columns: 1fr 1fr;
    }
  }
  @media (max-width: 640px) {
    .journal-grid {
      grid-template-columns: 1fr;
    }
    .section-header {
      flex-direction: column;
      align-items: flex-start;
      gap: var(--space-4);
    }
  }
</style>

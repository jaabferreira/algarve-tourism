---
import type { Locale, NormalizedItem } from "@algarve-tourism/shared";
import { LOCALES, t, buildBreadcrumbList, parseDescription } from "@algarve-tourism/shared";
import Layout from "../../../layouts/Layout.astro";
import Header from "@algarve-tourism/shared/components/Header.astro";
import Footer from "@algarve-tourism/shared/components/Footer.astro";
import ProductHero from "@algarve-tourism/shared/components/ProductHero.astro";
import BookingWidget from "@algarve-tourism/shared/components/BookingWidget.astro";
import ProductGrid from "@algarve-tourism/shared/components/ProductGrid.astro";
import WhatsAppButton from "@algarve-tourism/shared/components/WhatsAppButton.astro";
import MeetingPointMap from "@algarve-tourism/shared/components/MeetingPointMap.astro";
import { config } from "../../../config.js";
import { loadItems, getVariants } from "../../../data.js";

export function getStaticPaths() {
  return LOCALES.flatMap((locale) => {
    const items = loadItems(locale);
    return items.map((item) => ({
      params: { locale, slug: item.slug },
      props: { item, locale },
    }));
  });
}

const { item } = Astro.props as { item: NormalizedItem };
const locale = Astro.params.locale as Locale;

const allItems = loadItems(locale);
const relatedItems = allItems.filter((i) => i.pk !== item.pk).slice(0, 3);

const parsed = parseDescription(item.description_html);

const productData = {
  "@context": "https://schema.org",
  "@type": ["Product", "TouristTrip"],
  name: item.name,
  description: parsed.description?.slice(0, 160) ?? item.description_text,
  image: item.images.map((img) => img.url),
  offers: {
    "@type": "Offer",
    priceCurrency: "EUR",
    price: (item.price_from_including_tax / 100).toFixed(2),
    availability: "https://schema.org/InStock",
  },
  ...(item.location && {
    touristType: "Leisure",
    itinerary: {
      "@type": "Place",
      geo: {
        "@type": "GeoCoordinates",
        latitude: item.location.latitude,
        longitude: item.location.longitude,
      },
    },
  }),
};

const breadcrumbData = buildBreadcrumbList(config, locale, [
  { name: "Home", path: "/" },
  { name: t(locale, "nav.tours"), path: "/tours/" },
  { name: item.name, path: `/tours/${item.slug}/` },
]);

const structuredData = [productData, breadcrumbData];

const localePaths: Partial<Record<Locale, string>> = {};
for (const loc of config.locales as Locale[]) {
  if (loc === locale) {
    localePaths[loc] = `/${loc}/tours/${item.slug}/`;
    continue;
  }
  const localeItems = loadItems(loc);
  const match = localeItems.find((i) => i.pk === item.pk);
  localePaths[loc] = match ? `/${loc}/tours/${match.slug}/` : `/${loc}/tours/`;
}
---

<Layout
  title={item.name}
  description={(parsed.description ?? item.description_text).slice(0, 160)}
  image={item.image_url}
  locale={locale}
  path={`/tours/${item.slug}/`}
  config={config}
  structuredData={structuredData}
>
  <Header slot="header" config={config} locale={locale} path={`/${locale}/tours/${item.slug}/`} localePaths={localePaths} />

  <div class="container product-detail">
    <ProductHero item={item} locale={locale} brand={config.brand} />

    <div class="product-detail__content">
      <div class="product-detail__body">
        {item.description_bullets.length > 0 && (
          <section>
            <h2>{t(locale, "product.highlights")}</h2>
            <ul class="product-detail__bullets">
              {item.description_bullets.map((bullet) => (
                <li>{bullet}</li>
              ))}
            </ul>
          </section>
        )}

        {(parsed.duration || parsed.accessibility) && (
          <div class="product-detail__info-row">
            {parsed.duration && (
              <span class="product-detail__info-item">
                <strong>{t(locale, "product.duration")}:</strong> {parsed.duration}
              </span>
            )}
            {parsed.accessibility && (
              <span class="product-detail__info-item product-detail__info-item--access">
                {parsed.accessibility}
              </span>
            )}
          </div>
        )}

        {parsed.description && (
          <section>
            <div class="product-detail__description">
              {parsed.description.split(/\n\n+/).filter(Boolean).map((para) => (
                <p>{para.replace(/\n/g, " ").trim()}</p>
              ))}
            </div>
          </section>
        )}

        {parsed.itinerary && parsed.itinerary.length > 0 && (
          <section>
            <h3>{t(locale, "product.itinerary")}</h3>
            <ol class="product-detail__itinerary">
              {parsed.itinerary.map((stop) => <li>{stop}</li>)}
            </ol>
          </section>
        )}

        {parsed.restrictions && parsed.restrictions.length > 0 && (
          <section>
            <h3>{t(locale, "product.restrictions")}</h3>
            <ul class="product-detail__list">
              {parsed.restrictions.map((r) => <li>{r}</li>)}
            </ul>
          </section>
        )}

        {parsed.extras && parsed.extras.length > 0 && (
          <section>
            <h3>{t(locale, "product.extras")}</h3>
            <ul class="product-detail__list">
              {parsed.extras.map((line) => <li>{line}</li>)}
            </ul>
          </section>
        )}

        {parsed.disclaimers && (
          <p class="product-detail__disclaimer">{parsed.disclaimers}</p>
        )}

        {item.location && (
          <MeetingPointMap
            latitude={item.location.latitude}
            longitude={item.location.longitude}
            address={item.location.address}
            city={item.location.city}
            locale={locale}
          />
        )}

        {item.cancellation_policy_html && (
          <section>
            <h3>{t(locale, "product.cancellation")}</h3>
            <div set:html={item.cancellation_policy_html} />
          </section>
        )}
      </div>

      <aside class="product-detail__sidebar">
        <BookingWidget
          item={item}
          companyShortname={config.fh.shortname}
          locale={locale}
          variants={getVariants(item.pk, locale)}
        />
      </aside>
    </div>

    {relatedItems.length > 0 && (
      <section class="section">
        <h2>{t(locale, "product.related")}</h2>
        <ProductGrid items={relatedItems} brand={config.brand} locale={locale} />
      </section>
    )}
  </div>

  <Footer slot="footer" config={config} locale={locale} />
  <WhatsAppButton phone={config.social.whatsapp} locale={locale} />
</Layout>

<style>
  .product-detail {
    padding-bottom: var(--space-16);
  }

  .product-detail__content {
    display: grid;
    grid-template-columns: 1fr 360px;
    gap: var(--space-10);
    margin-top: var(--space-10);
  }

  .product-detail__body {
    display: flex;
    flex-direction: column;
    gap: var(--space-8);
  }

  .product-detail__body section {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .product-detail__bullets {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .product-detail__bullets li::before {
    content: "\2713 ";
    color: var(--color-primary);
    font-weight: var(--weight-bold);
  }

  .product-detail__info-row {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-4);
    padding: var(--space-4) var(--space-5);
    background: var(--color-surface);
    border-radius: var(--radius-card);
    border: 1px solid var(--color-border);
    font-size: var(--text-sm);
    color: var(--color-text-muted);
  }

  .product-detail__info-item {
    display: flex;
    align-items: center;
    gap: var(--space-1);
  }

  .product-detail__info-item strong {
    color: var(--color-text);
    font-weight: var(--weight-medium);
  }

  .product-detail__description {
    font-size: var(--text-base);
    line-height: var(--leading-relaxed);
    color: var(--color-text-body);
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .product-detail__list {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    padding-left: var(--space-5);
    font-size: var(--text-base);
    line-height: var(--leading-relaxed);
    color: var(--color-text-body);
  }

  .product-detail__itinerary {
    list-style: none;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-1) var(--space-6);
    counter-reset: itinerary;
    padding: 0;
    margin: 0;
  }

  .product-detail__itinerary li {
    counter-increment: itinerary;
    display: flex;
    align-items: center;
    gap: var(--space-3);
    font-size: var(--text-sm);
    line-height: var(--leading-normal);
    color: var(--color-text-body);
    padding: var(--space-2) 0;
    border-bottom: 1px solid var(--color-border);
  }

  .product-detail__itinerary li::before {
    content: counter(itinerary);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 24px;
    height: 24px;
    background: var(--color-primary);
    color: #fff;
    font-size: var(--text-xs);
    font-weight: var(--weight-semibold);
    flex-shrink: 0;
  }

  @media (max-width: 480px) {
    .product-detail__itinerary {
      grid-template-columns: 1fr;
    }
  }

  .product-detail__disclaimer {
    font-size: var(--text-sm);
    font-style: italic;
    color: var(--color-text-muted);
    padding: var(--space-3) var(--space-4);
    border-left: 2px solid var(--color-border);
  }

  @media (max-width: 768px) {
    .product-detail__content {
      grid-template-columns: 1fr;
    }
  }
</style>

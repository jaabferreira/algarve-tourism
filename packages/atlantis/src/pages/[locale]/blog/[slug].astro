---
import { getCollection } from "astro:content";
import type { Locale } from "@algarve-tourism/shared";
import { LOCALES, t, buildBlogPosting, buildBreadcrumbList, getLocalePath } from "@algarve-tourism/shared";
import Layout from "../../../layouts/Layout.astro";
import Header from "@algarve-tourism/shared/components/Header.astro";
import Footer from "@algarve-tourism/shared/components/Footer.astro";
import WhatsAppButton from "@algarve-tourism/shared/components/WhatsAppButton.astro";
import RelatedTours from "@algarve-tourism/shared/components/RelatedTours.astro";
import CTABanner from "@algarve-tourism/shared/components/CTABanner.astro";
import { config, tagTourMap } from "../../../config.js";
import { loadItems } from "../../../data.js";
import { optimizeImageUrl } from "@algarve-tourism/shared";

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  return posts.map((post) => ({
    params: {
      locale: post.data.locale,
      slug: post.slug.replace(`${post.data.locale}/`, ""),
    },
    props: { post },
  }));
}

const { post } = Astro.props;
const locale = Astro.params.locale as Locale;
const slug = Astro.params.slug as string;
const { Content } = await post.render();
const toursHref = getLocalePath(locale, "/tours/");

const allPosts = await getCollection("blog");
const translations = allPosts.filter(
  (p) => p.data.translationKey === post.data.translationKey && p.data.locale !== locale
);
const alternateUrls = [
  { locale, href: `https://www.${config.domain}/${locale}/blog/${slug}/` },
  ...translations.map((p) => ({
    locale: p.data.locale as Locale,
    href: `https://www.${config.domain}/${p.data.locale}/blog/${p.slug.replace(`${p.data.locale}/`, "")}/`,
  })),
];

const localePaths: Partial<Record<Locale, string>> = { [locale]: `/${locale}/blog/${slug}/` };
for (const loc of config.locales as Locale[]) {
  if (loc === locale) continue;
  const match = translations.find((p) => p.data.locale === loc);
  localePaths[loc] = match
    ? `/${loc}/blog/${match.slug.replace(`${loc}/`, "")}/`
    : `/${loc}/blog/`;
}

const categoryLabel = t(locale, `blog.category.${post.data.category}` as any);

const structuredData = [
  buildBlogPosting(config, {
    title: post.data.title,
    excerpt: post.data.excerpt,
    date: post.data.date,
    lastModified: post.data.lastModified,
    author: post.data.author,
    image: post.data.image,
    slug,
    category: categoryLabel,
    tags: post.data.tags,
  }, locale),
  buildBreadcrumbList(config, locale, [
    { name: "Home", path: "/" },
    { name: t(locale, "nav.blog"), path: "/blog/" },
    { name: categoryLabel, path: `/blog/category/${post.data.category}/` },
    { name: post.data.title, path: `/blog/${slug}/` },
  ]),
];

const items = loadItems(locale);
const tags = post.data.tags ?? [];

const heroImage = post.data.image ? optimizeImageUrl(post.data.image, 1600) : null;
const formattedDate = new Date(post.data.date).toLocaleDateString(locale, {
  year: "numeric", month: "long", day: "numeric",
});
---

<Layout
  title={post.data.title}
  description={post.data.excerpt}
  image={post.data.image}
  type="article"
  locale={locale}
  path={`/blog/${slug}/`}
  config={config}
  structuredData={structuredData}
  publishedDate={post.data.date}
  modifiedDate={post.data.lastModified}
  articleSection={categoryLabel}
  articleTags={tags}
  alternateUrls={alternateUrls}
>
  <Header slot="header" config={config} locale={locale} path={`/${locale}/blog/${slug}/`} localePaths={localePaths} />

  <section class="post-hero">
    <div class="post-hero__inner container">
      <nav class="post-hero__breadcrumbs" aria-label="Breadcrumb">
        <a href={getLocalePath(locale, "/")}>{config.name}</a>
        <span class="post-hero__sep">/</span>
        <a href={getLocalePath(locale, "/blog/")}>{t(locale, "nav.blog")}</a>
        <span class="post-hero__sep">/</span>
        <a href={getLocalePath(locale, `/blog/category/${post.data.category}/`)}>{categoryLabel}</a>
      </nav>
      <span class="post-hero__badge">{categoryLabel}</span>
      <h1 class="post-hero__title">{post.data.title}</h1>
      <p class="post-hero__subtitle">{post.data.excerpt}</p>
      <div class="post-hero__meta">
        <time>{formattedDate}</time>
        {post.data.readingTime && (
          <>
            <span class="post-hero__dot">·</span>
            <span>{post.data.readingTime} {t(locale, "blog.reading_time")}</span>
          </>
        )}
      </div>
    </div>
  </section>

  {heroImage && (
    <div class="post-hero-image container" data-reveal>
      <img src={heroImage} alt={post.data.imageAlt ?? post.data.title} width="1600" height="900" />
    </div>
  )}

  <article class="section-sm" data-reveal>
    <div class="container">
      <div class="post-content">
        <Content />
      </div>

      {tags.length > 0 && (
        <div class="post-tags">
          <span class="post-tags__label">{t(locale, "blog.tags")}:</span>
          <div class="post-tags__list">
            {tags.map((tag) => (
              <a href={getLocalePath(locale, `/blog/tag/${tag}/`)} class="post-tag">
                {tag.replace(/-/g, " ")}
              </a>
            ))}
          </div>
        </div>
      )}

      <RelatedTours
        tags={tags}
        locale={locale}
        brand={config.brand}
        items={items}
        tagTourMap={tagTourMap}
        relatedTourSlugs={post.data.relatedTourSlugs}
      />
    </div>
  </article>

  <CTABanner
    title={t(locale, "cta.explore_title")}
    subtitle={t(locale, "cta.explore_subtitle")}
    buttonText={t(locale, "cta.explore_button")}
    buttonHref={toursHref}
  />

  <Footer slot="footer" config={config} locale={locale} />
  <WhatsAppButton phone={config.social.whatsapp} locale={locale} />
</Layout>

<style>
  .post-hero {
    background: linear-gradient(135deg, #0A1A2A 0%, #0C3547 40%, #0E6B7A 70%, #1AABB8 100%);
    padding: calc(var(--header-height) + var(--space-12)) 0 var(--space-12);
    color: white;
    text-align: center;
  }

  .post-hero__inner {
    max-width: 780px;
  }

  .post-hero__breadcrumbs {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--space-2);
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.65);
    margin-bottom: var(--space-6);
  }

  .post-hero__breadcrumbs a {
    color: rgba(255, 255, 255, 0.75);
    text-decoration: none;
    transition: color var(--transition-fast);
  }

  .post-hero__breadcrumbs a:hover {
    color: var(--color-primary-light);
  }

  .post-hero__sep {
    opacity: 0.5;
  }

  .post-hero__badge {
    display: inline-block;
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: var(--tracking-widest);
    color: var(--color-primary-light);
    margin-bottom: var(--space-4);
  }

  .post-hero__title {
    font-family: var(--font-accent), Georgia, serif;
    font-size: var(--text-5xl);
    font-weight: var(--weight-regular);
    line-height: var(--leading-tight);
    margin: 0 0 var(--space-5) 0;
    letter-spacing: var(--tracking-tight);
  }

  .post-hero__subtitle {
    font-size: var(--text-lg);
    color: rgba(255, 255, 255, 0.75);
    margin: 0 0 var(--space-6) 0;
    line-height: var(--leading-relaxed);
  }

  .post-hero__meta {
    display: inline-flex;
    align-items: center;
    gap: var(--space-3);
    font-size: var(--text-sm);
    color: rgba(255, 255, 255, 0.6);
    letter-spacing: var(--tracking-wide);
  }

  .post-hero__dot {
    opacity: 0.5;
  }

  .post-hero-image {
    margin-top: calc(var(--space-12) * -1);
    margin-bottom: var(--space-12);
    position: relative;
    z-index: 1;
  }

  .post-hero-image img {
    width: 100%;
    height: auto;
    aspect-ratio: 16 / 9;
    object-fit: cover;
    border-radius: var(--radius-card);
    box-shadow: 0 30px 60px -20px rgba(10, 26, 42, 0.4);
  }

  .post-content {
    max-width: 720px;
    margin: 0 auto;
    font-size: var(--text-lg);
    line-height: var(--leading-loose);
    color: var(--color-text-body);
  }

  .post-content :global(p) {
    margin: 0 0 var(--space-6) 0;
  }

  .post-content :global(p:first-of-type::first-letter) {
    font-family: var(--font-accent), Georgia, serif;
    font-size: 4.25rem;
    font-weight: var(--weight-regular);
    font-style: italic;
    color: var(--color-primary);
    float: left;
    line-height: 0.9;
    padding: 0.3rem var(--space-3) 0 0;
  }

  .post-content :global(h2) {
    font-family: var(--font-accent), Georgia, serif;
    font-size: var(--text-3xl);
    font-weight: var(--weight-regular);
    line-height: var(--leading-tight);
    color: var(--color-text);
    margin: var(--space-12) 0 var(--space-4);
    letter-spacing: var(--tracking-tight);
  }

  .post-content :global(h3) {
    font-family: var(--font-accent), Georgia, serif;
    font-size: var(--text-2xl);
    font-weight: var(--weight-regular);
    font-style: italic;
    color: var(--color-text);
    margin: var(--space-10) 0 var(--space-3);
  }

  .post-content :global(a) {
    color: var(--color-primary);
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 3px;
  }

  .post-content :global(a:hover) {
    color: var(--color-primary-light);
  }

  .post-content :global(strong) {
    color: var(--color-text);
    font-weight: var(--weight-semibold);
  }

  .post-content :global(blockquote) {
    margin: var(--space-8) 0;
    padding: var(--space-2) 0 var(--space-2) var(--space-6);
    border-left: 3px solid var(--color-primary);
    font-family: var(--font-accent), Georgia, serif;
    font-style: italic;
    font-size: var(--text-xl);
    color: var(--color-text);
    line-height: var(--leading-relaxed);
  }

  .post-content :global(ul),
  .post-content :global(ol) {
    margin: 0 0 var(--space-6) 0;
    padding-left: var(--space-6);
  }

  .post-content :global(li) {
    margin-bottom: var(--space-2);
  }

  .post-content :global(img) {
    width: 100%;
    height: auto;
    border-radius: var(--radius-card);
    margin: var(--space-8) 0;
  }

  .post-content :global(hr) {
    border: none;
    border-top: 1px solid var(--color-border);
    margin: var(--space-10) 0;
  }

  .post-tags {
    max-width: 720px;
    margin: var(--space-10) auto 0;
    padding-top: var(--space-6);
    border-top: 1px solid var(--color-border);
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-3);
  }

  .post-tags__label {
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: var(--tracking-widest);
    color: var(--color-text-muted);
    font-weight: var(--weight-semibold);
  }

  .post-tags__list {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  .post-tag {
    display: inline-block;
    padding: var(--space-1) var(--space-3);
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    border: 1px solid var(--color-border);
    border-radius: 999px;
    text-decoration: none;
    text-transform: capitalize;
    transition: border-color var(--transition-fast), color var(--transition-fast);
  }

  .post-tag:hover {
    border-color: var(--color-primary);
    color: var(--color-primary);
  }

  @media (max-width: 768px) {
    .post-hero {
      padding: calc(var(--header-height) + var(--space-8)) 0 var(--space-8);
    }

    .post-hero__title {
      font-size: var(--text-3xl);
    }

    .post-hero-image {
      margin-top: calc(var(--space-8) * -1);
      margin-bottom: var(--space-8);
    }

    .post-content :global(p:first-of-type::first-letter) {
      font-size: 3rem;
    }

    .post-content :global(h2) {
      font-size: var(--text-2xl);
    }
  }
</style>

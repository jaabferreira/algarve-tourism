---
import type { Locale } from "@algarve-tourism/shared";
import { LOCALES, t } from "@algarve-tourism/shared";
import PageLayout from "@algarve-tourism/shared/layouts/PageLayout.astro";
import Header from "@algarve-tourism/shared/components/Header.astro";
import Footer from "@algarve-tourism/shared/components/Footer.astro";
import { config } from "../../config.js";

export function getStaticPaths() {
  return LOCALES.map((locale) => ({ params: { locale } }));
}

const locale = Astro.params.locale as Locale;
---

<PageLayout
  title={t(locale, "footer.terms")}
  description={`${t(locale, "footer.terms")} — ${config.name}`}
  locale={locale}
  path="/terms/"
  config={config}
>
  <Header slot="header" config={config} locale={locale} path={`/${locale}/terms/`} />

  <section class="section container" style={`padding-top: calc(var(--header-height) + var(--space-12))`}>
    <h1>{t(locale, "footer.terms")}</h1>
    <div class="page-content">
      <h2>1. Company Information</h2>
      <p>P4Y Services - Mediacao Imobiliaria, Lda<br/>
      Rua Sophia Mello Breyner, Lote 43, Fraccao C, 8200-084 Albufeira<br/>
      RNAAT Licence: 847/2020 | Tax Number: 516 094 464</p>

      <h2>2. Booking Process</h2>
      <p>Full payment is required at the time of booking. Upon confirmation, you will receive an email confirmation which serves as your voucher. Please present this voucher on the day of your experience.</p>

      <h2>3. Conditions of Access</h2>
      <p>Our maritime experiences are not suitable for individuals with back problems, pregnant women, persons with heart conditions, or wheelchair users. Participants must be in adequate physical condition. Children must be accompanied by a responsible adult at all times.</p>

      <h2>4. Clothing and Preparation</h2>
      <p>Please arrive at the meeting point at least 30 minutes before the scheduled departure. Wear comfortable clothing and bring sunscreen, a hat, and a towel. We provide life jackets and all required safety equipment.</p>

      <h2>5. Liability and Risks</h2>
      <p>Maritime activities carry inherent risks. By booking, you acknowledge these risks and agree that P4Y Services shall not be liable for any injury, loss, or damage arising from participation, except where caused by our negligence. Participants engage in all activities at their own risk.</p>

      <h2>6. Insurance and Safety</h2>
      <p>All our vessels carry Civil Liability Insurance as required by Portuguese maritime law. Life jackets are provided and must be worn when instructed by the crew. Failure to return a life jacket will result in a charge of €70.</p>

      <h2>7. Pets</h2>
      <p>Only certified service animals are permitted on our vessels. No other pets are allowed.</p>

      <h2>8. Data Protection</h2>
      <p>We process personal data in accordance with the General Data Protection Regulation (GDPR). Your data is used solely for booking management, communication regarding your experience, and legal compliance. You may request access to, correction of, or deletion of your personal data at any time.</p>

      <h2>9. Image Capture</h2>
      <p>In accordance with Article 79 of the Portuguese Civil Code, photographs and videos may be taken during experiences for promotional purposes. If you do not wish to appear in promotional materials, please inform the crew before departure.</p>

      <h2>10. Customer Conduct</h2>
      <p>The captain and crew reserve the right to refuse boarding or remove any passenger who is intoxicated, disruptive, or poses a safety risk to themselves or others. No refund will be provided in such cases.</p>

      <h2>11. Governing Law</h2>
      <p>These terms are governed by Portuguese law. Any disputes shall be resolved in the competent Portuguese courts.</p>

      <h2>12. Complaints</h2>
      <p>Complaints will be acknowledged within 5 business days and resolved within 30 days. You may also submit complaints via the official <a href="https://www.livroreclamacoes.pt/Inicio/" target="_blank" rel="noopener noreferrer">Livro de Reclamações</a>.</p>
    </div>
  </section>

  <Footer slot="footer" config={config} locale={locale} />
</PageLayout>

<style>
  .page-content { max-width: 680px; margin-top: var(--space-8); line-height: var(--line-height-relaxed); color: var(--text-secondary); }
</style>

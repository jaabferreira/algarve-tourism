---
import type { BrandConfig, Locale } from "../types.js";
import type { TranslationKey } from "../i18n/types.js";
import { t } from "../i18n/index.js";
import { getLocalePath } from "../config.js";
import LanguageSwitcher from "./LanguageSwitcher.astro";

interface Props {
  config: BrandConfig;
  locale: Locale;
  path: string;
}

const { config, locale, path } = Astro.props;
const brand = config.brand;

interface NavItem {
  label: string;
  href: string;
}

const navItems: NavItem[] =
  brand === "atlantis"
    ? [
        { label: t(locale, "nav.tours"), href: getLocalePath(locale, "/tours/") },
        { label: t(locale, "nav.about"), href: getLocalePath(locale, "/about/") },
        { label: t(locale, "nav.reviews"), href: getLocalePath(locale, "/reviews/") },
        { label: t(locale, "nav.blog"), href: getLocalePath(locale, "/blog/") },
        { label: t(locale, "nav.contact"), href: getLocalePath(locale, "/contact/") },
      ]
    : [
        { label: t(locale, "nav.experiences"), href: getLocalePath(locale, "/tours/") },
        { label: t(locale, "nav.journal"), href: getLocalePath(locale, "/blog/") },
        { label: t(locale, "nav.about"), href: getLocalePath(locale, "/about/") },
        { label: t(locale, "nav.contact"), href: getLocalePath(locale, "/contact/") },
      ];

const ctaLabel = t(locale, "nav.book_now");
const ctaHref = `https://fareharbor.com/embeds/book/${config.fh.shortname}/?full-items=yes&flow=${config.fh.flow}`;
---

<header class="header" data-brand={brand}>
  <div class="header__inner">
    <a href={getLocalePath(locale, "/")} class="logo" aria-label={config.name}>
      {brand === "atlantis" ? (
        <span class="logo__icon" aria-hidden="true">A</span>
        <span class="logo__text">
          atlantis<span class="logo__text--accent">tours</span>
        </span>
      ) : (
        <span class="logo__text">
          Algarve<span class="logo__ampersand">&</span>You
        </span>
      )}
    </a>

    <nav class="nav" aria-label="Main navigation">
      {navItems.map((item) => (
        <a href={item.href} class="nav-link">{item.label}</a>
      ))}
    </nav>

    <div class="header__actions">
      <LanguageSwitcher locale={locale} path={path} config={config} />
      <a href={ctaHref} class="nav-cta">
        {ctaLabel}
      </a>
    </div>

    <button class="mobile-toggle" aria-label="Open menu" aria-expanded="false" data-mobile-toggle>
      <span></span>
      <span></span>
      <span></span>
    </button>
  </div>

</header>

<!-- Mobile nav overlay — outside header to avoid stacking context containment -->
<div class="mobile-menu" data-mobile-nav data-brand={brand}>
  <nav class="mobile-menu__links">
    {navItems.map((item) => (
      <a href={item.href} class="mobile-menu__link">{item.label}</a>
    ))}
    <a href={ctaHref} class="nav-cta mobile-menu__cta">
      {ctaLabel}
    </a>
  </nav>
  <LanguageSwitcher locale={locale} path={path} config={config} />
</div>

<style>
  /* ===========================
     Shared header styles
     =========================== */
  .header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    height: var(--header-height);
    border-bottom: 1px solid var(--color-border);
    transition: background var(--transition-base);
  }

  .header__inner {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 var(--space-6);
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 100%;
    gap: var(--space-8);
  }

  /* Logo — shared */
  .logo {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    text-decoration: none;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .logo__text {
    font-family: var(--font-display);
    color: var(--color-text);
  }

  /* Nav — shared */
  .nav {
    display: flex;
    align-items: center;
    gap: var(--space-6);
  }

  .nav-link {
    text-decoration: none;
    transition: color var(--transition-fast);
  }

  /* Actions — shared */
  .header__actions {
    display: flex;
    align-items: center;
    gap: var(--space-4);
  }

  /* CTA — shared */
  .nav-cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    text-decoration: none;
    cursor: pointer;
    transition: opacity var(--transition-fast), transform var(--transition-fast);
    white-space: nowrap;
  }

  .nav-cta:hover {
    opacity: 0.9;
    transform: translateY(-1px);
  }

  /* Hamburger — shared */
  .mobile-toggle {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    padding: var(--space-2);
    cursor: pointer;
    min-width: 44px;
    min-height: 44px;
    align-items: center;
    justify-content: center;
  }

  .mobile-toggle span {
    display: block;
    width: 22px;
    height: 1.5px;
    background: var(--color-text);
    transition: all var(--transition-base);
  }

  .mobile-toggle.open span:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }

  .mobile-toggle.open span:nth-child(2) {
    opacity: 0;
  }

  .mobile-toggle.open span:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }

  /* Mobile menu — outside header to avoid stacking context issues */
  .mobile-menu {
    display: none;
    position: fixed;
    top: var(--header-height);
    left: 0;
    right: 0;
    z-index: 99;
    bottom: 0;
    background: var(--color-bg);
    padding: var(--space-8) var(--space-6);
    flex-direction: column;
    gap: var(--space-8);
    overflow-y: auto;
  }

  .mobile-menu.open {
    display: flex;
  }

  .mobile-menu__links {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .mobile-menu__link {
    font-family: var(--font-display);
    font-size: var(--text-3xl);
    font-weight: var(--weight-regular);
    color: var(--color-text);
    text-decoration: none;
  }

  .mobile-menu__cta {
    margin-top: var(--space-4);
    text-align: center;
  }

  @media (max-width: 768px) {
    .nav,
    .header__actions {
      display: none;
    }

    .mobile-toggle {
      display: flex;
    }
  }

  /* ===========================
     Atlantis — Coastal Modern
     =========================== */
  .header[data-brand="atlantis"]::before {
    content: "";
    position: absolute;
    inset: 0;
    background: rgba(247, 250, 251, 0.9);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    z-index: -1;
  }

  .header[data-brand="atlantis"] .logo__icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: 10px;
    background: linear-gradient(135deg, var(--color-primary), var(--color-primary-light));
    color: #fff;
    font-family: var(--font-display);
    font-size: 16px;
    font-weight: var(--weight-bold);
    line-height: 1;
    flex-shrink: 0;
  }

  .header[data-brand="atlantis"] .logo__text {
    font-size: 17px;
    font-weight: var(--weight-bold);
    letter-spacing: var(--tracking-tight);
  }

  .header[data-brand="atlantis"] .logo__text--accent {
    color: var(--color-primary);
  }

  .header[data-brand="atlantis"] .nav-link {
    font-size: 13px;
    font-weight: var(--weight-medium);
    color: var(--color-text-muted);
  }

  .header[data-brand="atlantis"] .nav-link:hover {
    color: var(--color-primary);
  }

  .header[data-brand="atlantis"] .nav-cta {
    background: linear-gradient(135deg, var(--color-primary), var(--color-primary-light));
    color: #fff;
    border-radius: 8px;
    padding: var(--space-2) var(--space-5);
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: var(--weight-semibold);
  }

  .mobile-menu[data-brand="atlantis"] {
    background: var(--color-bg);
  }

  /* ===========================
     Algarve & You — Mediterranean Editorial
     =========================== */
  .header[data-brand="algarve-and-you"]::before {
    content: "";
    position: absolute;
    inset: 0;
    background: rgba(250, 246, 240, 0.92);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    z-index: -1;
  }

  .header[data-brand="algarve-and-you"] .logo__text {
    font-size: var(--text-xl);
    font-weight: var(--weight-regular);
    letter-spacing: var(--tracking-tight);
  }

  .header[data-brand="algarve-and-you"] .logo__ampersand {
    font-style: italic;
    color: var(--color-primary);
    padding: 0 0.1em;
  }

  .header[data-brand="algarve-and-you"] .nav-link {
    font-size: 12px;
    font-weight: var(--weight-medium);
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.12em;
  }

  .header[data-brand="algarve-and-you"] .nav-link:hover {
    color: var(--color-text);
  }

  .header[data-brand="algarve-and-you"] .nav-cta {
    background: var(--color-text);
    color: var(--color-bg);
    border-radius: 0px;
    padding: var(--space-2) var(--space-5);
    font-family: var(--font-body);
    font-size: 11px;
    font-weight: var(--weight-medium);
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .mobile-menu[data-brand="algarve-and-you"] {
    background: var(--color-bg);
  }
</style>

<script>
  const toggle = document.querySelector("[data-mobile-toggle]");
  const nav = document.querySelector("[data-mobile-nav]");
  toggle?.addEventListener("click", () => {
    nav?.classList.toggle("open");
    toggle?.classList.toggle("open");
    const isOpen = nav?.classList.contains("open");
    document.body.style.overflow = isOpen ? "hidden" : "";
    toggle?.setAttribute("aria-expanded", isOpen ? "true" : "false");
  });
</script>

---
import type { BrandConfig, Locale } from "../types.js";
import { t } from "../i18n/index.js";
import type { TranslationKey } from "../i18n/types.js";
import { optimizeImageUrl, optimizeImageSrcset } from "../lib/images.js";
import HeroFloatCard from "./HeroFloatCard.astro";

interface Props {
  config: BrandConfig;
  locale: Locale;
  title: string;
  subtitle?: string;
  image?: string;
  ctaText?: string;
  ctaLink?: string;
  // For A&Y float card
  floatLabel?: string;
  floatTitle?: string;
  floatMeta?: string;
  floatHref?: string;
}

const {
  config,
  locale,
  title,
  subtitle,
  image,
  ctaText,
  ctaLink,
  floatLabel,
  floatTitle,
  floatMeta,
  floatHref,
} = Astro.props;

const brand = config.brand;
const isAtlantis = brand === "atlantis";
const isAY = brand === "algarve-and-you";

const showFloatCard = isAY && floatLabel && floatTitle && floatMeta;
---

<section class="hero" data-brand={brand}>
  {isAtlantis && (
    <div class="at-hero">
      {image ? (
        <div class="at-hero__bg-image" aria-hidden="true">
          <img
            src={optimizeImageUrl(image!, 1080, 75)}
            srcset={optimizeImageSrcset(image!, [750, 1080, 1440, 1920])}
            sizes="100vw"
            alt={title}
            width="1920"
            height="1080"
            loading="eager"
            fetchpriority="high"
          />
          <div class="at-hero__overlay"></div>
        </div>
      ) : (
        <div class="at-hero__bg-gradient" aria-hidden="true"></div>
      )}

      <div class="at-hero__circle" aria-hidden="true"></div>

      <div class="container at-hero__inner">
        <div class="at-hero__badge">
          <span class="at-hero__badge-dot" aria-hidden="true"></span>
          {t(locale, "hero.departing_daily")}
        </div>

        <h1 class="at-hero__title" set:html={title} />

        {subtitle && <p class="at-hero__subtitle">{subtitle}</p>}

        <div class="at-hero__ctas">
          {ctaText && ctaLink && (
            <a href={ctaLink} class="at-hero__cta-primary">{ctaText}</a>
          )}
          <a href={`/${locale}/tours/`} class="at-hero__cta-secondary">{t(locale, "hero.view_all_tours")}</a>
        </div>
      </div>

      <div class="at-hero__stats">
        <div class="container at-hero__stats-inner">
          <div class="at-hero__stat">
            <span class="at-hero__stat-number">14+</span>
            <span class="at-hero__stat-label">{t(locale, "hero.years_exp")}</span>
          </div>
          <div class="at-hero__stat">
            <span class="at-hero__stat-number">50k+</span>
            <span class="at-hero__stat-label">{t(locale, "hero.happy_explorers")}</span>
          </div>
          <div class="at-hero__stat">
            <span class="at-hero__stat-number">4.9</span>
            <span class="at-hero__stat-label">{t(locale, "hero.avg_rating")}</span>
          </div>
        </div>
      </div>
    </div>
  )}

  {isAY && (
    <div class="ay-hero">
      <div class="ay-hero__bg">
        {image ? (
          <img
            src={optimizeImageUrl(image!, 1080, 75)}
            srcset={optimizeImageSrcset(image!, [750, 1080, 1440, 1920])}
            sizes="100vw"
            alt={title}
            width="1920"
            height="1080"
            loading="eager"
            fetchpriority="high"
          />
        ) : (
          <div class="ay-hero__bg-placeholder" aria-hidden="true"></div>
        )}
        <div class="ay-hero__overlay" aria-hidden="true"></div>
        <div class="ay-hero__bottom-fade" aria-hidden="true"></div>
      </div>

      <div class="container ay-hero__inner">
        <div class="ay-hero__content">
          <div class="ay-hero__gold-line ay-hero__reveal" style="--reveal-delay: 0ms" aria-hidden="true"></div>
          <p class="ay-hero__overtitle ay-hero__reveal" style="--reveal-delay: 100ms">{config.name}</p>
          <h1 class="ay-hero__title ay-hero__reveal" style="--reveal-delay: 200ms" set:html={title} />
          {subtitle && <p class="ay-hero__subtitle ay-hero__reveal" style="--reveal-delay: 300ms">{subtitle}</p>}

          {config.fh.categories.length > 0 && (
            <div class="ay-hero__chips ay-hero__reveal" style="--reveal-delay: 400ms">
              <a href={`/${locale}/tours/`} class="ay-hero__chip active">{t(locale, "common.all")}</a>
              {config.fh.categories.map((slug) => (
                <a href={`/${locale}/tours/${slug}/`} class="ay-hero__chip">
                  {t(locale, `category.${slug}` as TranslationKey)}
                </a>
              ))}
            </div>
          )}

          <div class="ay-hero__ctas ay-hero__reveal" style="--reveal-delay: 500ms">
            {ctaText && ctaLink && (
              <a href={ctaLink} class="ay-hero__cta-primary">{ctaText}</a>
            )}
            <a href={`/${locale}/tours/`} class="ay-hero__cta-link">
              {t(locale, "hero.browse_collection")} <span aria-hidden="true">&rarr;</span>
            </a>
          </div>
        </div>
      </div>

      {showFloatCard && (
        <div class="ay-hero__float-wrap">
          <HeroFloatCard
            label={floatLabel!}
            title={floatTitle!}
            meta={floatMeta!}
            href={floatHref}
          />
        </div>
      )}
    </div>
  )}
</section>

<style>
  /* ===========================
     SHARED
     =========================== */
  .hero {
    position: relative;
    overflow: hidden;
  }

  /* ===========================
     ATLANTIS — Full-width gradient
     =========================== */
  .at-hero {
    position: relative;
    min-height: 85vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    background: linear-gradient(135deg, #0A1A2A 0%, #0C3547 30%, #0E6B7A 60%, #1AABB8 100%);
    color: #fff;
  }

  .at-hero__bg-image {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .at-hero__bg-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .at-hero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      135deg,
      rgba(10, 26, 42, 0.75) 0%,
      rgba(12, 53, 71, 0.55) 50%,
      rgba(14, 107, 122, 0.40) 100%
    );
  }

  .at-hero__bg-gradient {
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, #0A1A2A 0%, #0C3547 30%, #0E6B7A 60%, #1AABB8 100%);
    z-index: 0;
  }

  .at-hero__circle {
    position: absolute;
    top: -80px;
    right: -60px;
    width: 300px;
    height: 300px;
    border-radius: 50%;
    background: rgba(26, 171, 184, 0.12);
    z-index: 1;
    pointer-events: none;
  }

  .at-hero__inner {
    position: relative;
    z-index: 2;
    padding-top: calc(var(--header-height) + var(--space-16));
    padding-bottom: var(--space-16);
    max-width: 680px;
  }

  /* Badge */
  .at-hero__badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    background: rgba(255, 255, 255, 0.08);
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 24px;
    padding: 8px 16px;
    margin-bottom: var(--space-8);
    color: rgba(255, 255, 255, 0.85);
  }

  .at-hero__badge-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #1AABB8;
    animation: pulse-dot 2s ease-in-out infinite;
    flex-shrink: 0;
  }

  @keyframes pulse-dot {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.5; transform: scale(1.4); }
  }

  /* Title */
  .at-hero__title {
    font-family: var(--font-display);
    font-size: clamp(40px, 6vw, 64px);
    font-weight: 700;
    color: #fff;
    letter-spacing: -0.04em;
    line-height: 1.02;
    margin: 0;
  }

  .at-hero__title :global(em) {
    font-family: var(--font-accent);
    font-style: italic;
    color: var(--color-accent-light);
  }

  /* Subtitle */
  .at-hero__subtitle {
    margin-top: var(--space-5);
    font-size: 17px;
    color: rgba(255, 255, 255, 0.65);
    line-height: 1.6;
    max-width: 440px;
  }

  /* CTAs */
  .at-hero__ctas {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    margin-top: var(--space-8);
    flex-wrap: wrap;
  }

  .at-hero__cta-primary {
    display: inline-flex;
    align-items: center;
    padding: 12px 28px;
    background: #fff;
    color: #0A1A2A;
    font-size: 14px;
    font-weight: 600;
    border-radius: 10px;
    text-decoration: none;
    transition: transform var(--transition-fast), box-shadow var(--transition-fast);
  }

  .at-hero__cta-primary:hover {
    transform: translateY(-1px);
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.2);
  }

  .at-hero__cta-secondary {
    display: inline-flex;
    align-items: center;
    padding: 12px 28px;
    background: transparent;
    color: #fff;
    font-size: 14px;
    font-weight: 500;
    border-radius: 10px;
    border: 1px solid rgba(255, 255, 255, 0.25);
    backdrop-filter: blur(8px);
    text-decoration: none;
    transition: background var(--transition-fast), border-color var(--transition-fast);
  }

  .at-hero__cta-secondary:hover {
    background: rgba(255, 255, 255, 0.08);
    border-color: rgba(255, 255, 255, 0.4);
  }

  /* Stats bar */
  .at-hero__stats {
    position: relative;
    z-index: 2;
    border-top: 1px solid rgba(255, 255, 255, 0.08);
    margin-top: auto;
  }

  .at-hero__stats-inner {
    display: flex;
    gap: var(--space-12);
    padding-block: var(--space-6);
  }

  .at-hero__stat {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .at-hero__stat-number {
    font-size: 28px;
    font-weight: 700;
    color: #fff;
    line-height: 1;
  }

  .at-hero__stat-label {
    font-size: 12px;
    color: rgba(255, 255, 255, 0.45);
    letter-spacing: 0.02em;
  }

  /* Atlantis mobile */
  @media (max-width: 768px) {
    .at-hero {
      min-height: 75vh;
    }

    .at-hero__title {
      font-size: clamp(32px, 8vw, 44px);
    }

    .at-hero__stats-inner {
      gap: var(--space-8);
    }

    .at-hero__stat-number {
      font-size: 22px;
    }
  }

  /* ===========================
     ALGARVE & YOU — Full-bleed image
     =========================== */
  .ay-hero {
    position: relative;
    min-height: 85vh;
    display: flex;
    align-items: center;
  }

  /* Background image */
  .ay-hero__bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .ay-hero__bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ay-hero__bg-placeholder {
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, var(--color-bg-alt) 0%, var(--color-border) 100%);
  }

  .ay-hero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      90deg,
      rgba(250, 248, 246, 0.95) 0%,
      rgba(250, 248, 246, 0.85) 30%,
      rgba(250, 248, 246, 0.4) 55%,
      transparent 75%
    );
  }

  .ay-hero__bottom-fade {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 120px;
    background: linear-gradient(to top, var(--color-bg), transparent);
    z-index: 1;
  }

  /* Content */
  .ay-hero__inner {
    position: relative;
    z-index: 2;
    padding-top: calc(var(--header-height) + var(--space-12));
    padding-bottom: var(--space-12);
    max-width: none;
    margin: 0;
    padding-left: var(--space-12);
    padding-right: var(--space-12);
  }

  .ay-hero__content {
    max-width: 480px;
  }

  .ay-hero__gold-line {
    width: 48px;
    height: 1px;
    background: var(--color-accent);
    margin-bottom: 20px;
  }

  /* Staggered entrance */
  @keyframes ay-reveal {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .ay-hero__reveal {
    opacity: 0;
    animation: ay-reveal 600ms ease-out forwards;
    animation-delay: var(--reveal-delay, 0ms);
  }

  @media (prefers-reduced-motion: reduce) {
    .ay-hero__reveal {
      opacity: 1;
      animation: none;
    }
  }

  .ay-hero__overtitle {
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--color-primary);
    font-weight: 500;
    margin: 0 0 var(--space-5) 0;
  }

  .ay-hero__title {
    font-family: var(--font-display);
    font-size: clamp(38px, 4.5vw, 58px);
    font-weight: 300;
    color: var(--color-text);
    line-height: 1.08;
    margin: 0;
  }

  .ay-hero__title :global(em) {
    font-style: italic;
    font-weight: 600;
    color: var(--color-primary);
  }

  .ay-hero__subtitle {
    margin-top: var(--space-5);
    font-size: 16px;
    color: var(--color-text-body);
    line-height: 1.75;
    max-width: 420px;
  }

  /* Category pills */
  .ay-hero__chips {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    margin-top: var(--space-8);
  }

  .ay-hero__chip {
    display: inline-block;
    font-size: 12px;
    letter-spacing: 0.06em;
    padding: 6px 16px;
    border: 1px solid rgba(0, 0, 0, 0.15);
    color: var(--color-text-muted);
    background: rgba(255, 255, 255, 0.5);
    backdrop-filter: blur(4px);
    text-decoration: none;
    transition: all var(--transition-base);
    cursor: pointer;
  }

  .ay-hero__chip:hover {
    border-color: var(--color-text);
    color: var(--color-text);
    background: rgba(255, 255, 255, 0.7);
  }

  .ay-hero__chip.active {
    background: var(--color-primary);
    color: #fff;
    border-color: var(--color-primary);
  }

  .ay-hero__chip.active:hover {
    background: var(--color-primary-dark);
    border-color: var(--color-primary-dark);
  }

  /* CTAs */
  .ay-hero__ctas {
    display: flex;
    align-items: center;
    gap: var(--space-6);
    margin-top: var(--space-8);
    flex-wrap: wrap;
  }

  .ay-hero__cta-primary {
    display: inline-flex;
    align-items: center;
    padding: 14px 32px;
    background: var(--color-primary);
    color: #fff;
    font-size: 12px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    text-decoration: none;
    border-radius: var(--radius-button);
    transition: background var(--transition-base), transform var(--transition-fast);
  }

  .ay-hero__cta-primary:hover {
    background: var(--color-primary-dark);
    transform: translateY(-1px);
  }

  .ay-hero__cta-link {
    font-size: 14px;
    color: var(--color-text);
    text-decoration: none;
    font-weight: 500;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    transition: color var(--transition-fast);
  }

  .ay-hero__cta-link:hover {
    color: var(--color-primary);
  }

  .ay-hero__cta-link span {
    transition: transform var(--transition-fast);
  }

  .ay-hero__cta-link:hover span {
    transform: translateX(3px);
  }

  /* Float card */
  .ay-hero__float-wrap {
    position: absolute;
    bottom: var(--space-10);
    right: var(--space-10);
    z-index: 3;
  }

  /* A&Y mobile */
  @media (max-width: 768px) {
    .ay-hero {
      min-height: 75vh;
    }

    .ay-hero__overlay {
      background: linear-gradient(
        to top,
        rgba(250, 248, 246, 0.95) 0%,
        rgba(250, 248, 246, 0.8) 50%,
        rgba(250, 248, 246, 0.3) 100%
      );
    }

    .ay-hero__inner {
      padding-top: calc(var(--header-height) + 30vh);
    }

    .ay-hero__content {
      max-width: none;
    }

    .ay-hero__title {
      font-size: clamp(32px, 7vw, 42px);
    }

    .ay-hero__float-wrap {
      display: none;
    }
  }
</style>

<script>
  // Parallax for hero images
  const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  if (!reducedMotion) {
    const atImg = document.querySelector('.at-hero__bg-image') as HTMLElement | null;
    const ayImg = document.querySelector('.ay-hero__bg') as HTMLElement | null;
    const target = atImg || ayImg;
    if (target) {
      let ticking = false;
      window.addEventListener('scroll', () => {
        if (!ticking) {
          requestAnimationFrame(() => {
            const scrollY = window.scrollY;
            if (scrollY < window.innerHeight) {
              target.style.transform = `translateY(${scrollY * 0.25}px)`;
            }
            ticking = false;
          });
          ticking = true;
        }
      }, { passive: true });
    }
  }
</script>

---
import type { Locale } from "../types.js";
import { t } from "../i18n/index.js";
import { formatPrice } from "../lib/prices.js";

interface Props {
  cents: number;
  locale: Locale;
  size?: "sm" | "md" | "lg";
}

const { cents, locale, size = "md" } = Astro.props;
---

<span class:list={["price", `price--${size}`]}>
  <span class="price__from">{t(locale, "product.from")}</span>
  <span class="price__amount">{formatPrice(cents)}</span>
</span>

<style>
  .price {
    display: inline-flex;
    align-items: baseline;
    gap: var(--space-2);
  }

  .price__from {
    font-size: var(--text-xs);
    font-weight: var(--weight-regular);
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wider);
  }

  .price__amount {
    font-family: var(--font-display);
    font-weight: var(--weight-semibold);
    color: var(--color-text);
  }

  .price--sm .price__amount { font-size: var(--text-xl); }
  .price--md .price__amount { font-size: var(--text-2xl); }
  .price--lg .price__amount { font-size: var(--text-4xl); }
</style>
